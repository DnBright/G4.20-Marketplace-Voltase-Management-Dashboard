flowchart TD
    %% Styles Reflected from Image
    classDef startend fill:#F4CCCC,stroke:#333,stroke-width:2px
    classDef process fill:#FFF2CC,stroke:#333,stroke-width:2px
    classDef io fill:#DAE8FC,stroke:#333,stroke-width:2px
    classDef decision fill:#FCE5CD,stroke:#333,stroke-width:2px
    
    %% Nodes
    Start([Mulai])
    RunScript[Jalankan Script Scraping]
    RawData[/"Data Mentah Diperoleh"/]
    DecisionValid{"Data Valid?"}
    PreProcess["Pre-processing & Cleaning<br/>(Regex & Standarisasi)"]
    CleanData[/"Data Bersih CSV"/]
    ImportDB[Import ke Database MySQL]
    BackendProc["Pemrosesan Backend (Laravel)"]
    VisualOutput[/"Visualisasi Dashboard (Chart.js)"/]
    End([Selesai])

    %% Flows
    Start:::startend --> RunScript:::process
    RunScript --> RawData:::io
    RawData --> DecisionValid:::decision
    DecisionValid -- Tidak --> RunScript
    DecisionValid -- Ya --> PreProcess:::process
    PreProcess --> CleanData:::io
    CleanData --> ImportDB:::process
    ImportDB --> BackendProc:::process
    BackendProc --> VisualOutput:::io
    VisualOutput --> End:::startend
